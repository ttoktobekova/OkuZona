<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/authFragment">

    <!-- 1. Экран Входа / Регистрации -->
    <fragment
        android:id="@+id/authFragment"
        android:name="com.example.okuzona.AuthFragment"
        android:label="Авторизация"
        tools:layout="@layout/fragment_auth" >
        <action
            android:id="@+id/action_authFragment_to_bookListFragment"
            app:destination="@id/bookListFragment"
            app:popUpTo="@id/nav_graph"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- 2. Экран со списком книг -->
    <fragment
        android:id="@+id/bookListFragment"
        android:name="com.example.okuzona.BookListFragment"
        android:label="fragment_book_list"
        tools:layout="@layout/fragment_book_list" >
        <action
            android:id="@+id/action_bookListFragment_to_bookReaderFragment"
            app:destination="@id/bookReaderFragment" />
    </fragment>

    <!-- 3. Экран читалки PDF книг -->
    <fragment
        android:id="@+id/bookReaderFragment"
        android:name="com.example.okuzona.BookReaderFragment"
        android:label="fragment_book_reader"
        tools:layout="@layout/fragment_book_reader">
        <argument
            android:name="pdfUrl"
            app:argType="string" />
    </fragment>

</navigation>
